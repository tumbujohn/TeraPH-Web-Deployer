# ============================================================
# TeraPH Web Deployer — .gitignore
# ============================================================

# --- Sensitive config (never commit) ---
config.php

# --- Database (environment-specific, never share across installs) ---
storage/deployer.db
storage/*.db

# --- Storage runtime content (logs, backups, uploads, cache) ---
# Each subdirectory keeps its own .gitignore so the dir is tracked but contents are not.
storage/deploy_strategy.txt

# --- OS files ---
.DS_Store
Thumbs.db

# --- IDE / editor ---
.vscode/
*.swp
*.swo

# --- Build output ---
dist/
build/
node_modules/

# --- Claude AI workspace file ---
CLAUDE.md
