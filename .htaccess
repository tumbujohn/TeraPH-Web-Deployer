# ============================================================================
# TeraPH Web Deployer — Root .htaccess
# ============================================================================

# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Prevent directory listing
Options -Indexes

# ----------------------------------------------------------------------------
# 1. Block access to config and structural internals
# ----------------------------------------------------------------------------
<FilesMatch "^(config\.php|\.env|\.git|\.gitignore|\.htaccess|tera)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ----------------------------------------------------------------------------
# 2. Transparently Route All Traffic to /public/
# ----------------------------------------------------------------------------
# If the user drops this whole folder into public_html instead of mapping a 
# subdomain specifically to /public, this ensures all traffic is securely 
# forced downward into the public directory.

RewriteCond %{REQUEST_URI} !public/
RewriteRule ^(.*)$ public/$1 [L]


