# ============================================================================
# TeraPH Web Deployer — Root .htaccess
# ============================================================================

# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block direct access to config and app internals
<FilesMatch "^config\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to composer files and dot files
<FilesMatch "^\.(env|git|gitignore|htaccess)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Do not allow PHP execution in this directory except via web server
<Files "*.php">
    Order allow,deny
    Allow from all
</Files>
